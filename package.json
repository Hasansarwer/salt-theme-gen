{
  "name": "salt-theme-gen",
  "version": "1.1.2",
  "description": "OKLCH-based design system generator — generate complete themes from a single color. Platform agnostic: React Native, React, Next.js, Node, Bun, Deno.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "private": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "theme",
    "design-system",
    "oklch",
    "color",
    "generator",
    "typescript",
    "salt",
    "palette",
    "wcag",
    "accessibility",
    "dark-mode",
    "color-science",
    "perceptual",
    "react-native",
    "react",
    "nextjs",
    "platform-agnostic"
  ],
  "author": "hasansarwer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hasansarwer/salt-theme-gen"
  },
  "type": "commonjs",
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}

{
  "name": "salt-theme-gen",
  "version": "1.1.0",
  "description": "OKLCH-based design system generator for React Native — generate complete themes from a single color",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "private": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react-native",
    "theme",
    "design-system",
    "oklch",
    "color",
    "generator",
    "typescript",
    "salt",
    "palette",
    "wcag",
    "accessibility",
    "dark-mode",
    "color-science",
    "perceptual"
  ],
  "author": "hasan_sarwer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hasansarwer/salt-theme-gen"
  },
  "type": "commonjs",
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
